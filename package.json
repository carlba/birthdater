{
  "name": "birthdater",
  "description": "Update Google Contacts birthdays from a CSV file",
  "version": "0.0.1",
  "private": true,
  "bin": {
    "birthdater": "dist/google-contacts.js"
  },
  "license": "UNLICENSED",
  "type": "module",
  "author": "carlba",
  "homepage": "https://github.com/carlba/birthdater",
  "bugs": {
    "url": "https://github.com/carlba/birthdater/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:carlba/birthdater.git"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --env-file .env dist/google-contacts.js",
    "start:prod": "node dist/google-contacts.js",
    "start:dev": "nodemon --exec \"node --env-file .env --loader tsx\" src/google-contacts.ts",
    "search-contact": "tsx --env-file .env src/google-contacts.ts --search",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dependency:update": "npx ncu -u -x eslint",
    "linux:install": "docker run --rm --platform linux/amd64 -v \"$PWD\":/app -w /app node:24-bullseye bash -lc \"npm install\"",
    "linux:ci": "docker run --rm --platform linux/amd64 -v \"$PWD\":/app -w /app node:24-bullseye bash -lc \"npm ci && npm run lint && npm test && npm run build\""
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "eslint": "^9.39.2",
    "nodemon": "^3.1.14",
    "npm-check-updates": "^20.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "commander": "^11.0.0",
    "got": "^12.3.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.3.6"
  }
}
